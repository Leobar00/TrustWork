# Environment Variables Template
# Copy this file to .env and fill in your actual values

# OpenAI API Key (required for AI validation)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Tether WDK Configuration
WDK_API_KEY=your-wdk-api-key-here
WDK_NETWORK=testnet
WDK_CONTRACT_ADDRESS=

# JWT Secret (generate a secure random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Database (only change if not using docker-compose defaults)
DATABASE_URL=postgresql://trustwork:trustwork_dev_password@localhost:5432/trustwork

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Node Environment
NODE_ENV=development
